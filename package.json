{
  "name": "angular-starter",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:host": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "build:watch": "ng build --watch --configuration development",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.spec.json",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "test:coverage": "ng test --coverage --watch=false",
    "e2e": "ng e2e",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report ./.artifacts/e2e/playwright-report",
    "check": "pnpm format:check && pnpm lint && pnpm test:ci",
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm format:check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,html}": "eslint --fix",
    "*.{ts,js,json,md,html,css,scss,yml,yaml}": "prettier --write"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-angular": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "playwright-ng-schematics": "^21.0.10",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
